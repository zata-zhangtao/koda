# Reference values for externally provided server environment variables
# TLS is handled by Dokploy/Traefik — no ACME config needed here.

# Browser-facing Basic Auth
CADDY_BASICAUTH_USER=koda
CADDY_BASICAUTH_PASSWORD=replace-with-browser-password
# Optional: pre-generated hash fallback. If both are set, plaintext wins.
# CADDY_BASICAUTH_HASH=replace-with-caddy-hash

# Public tunnel routing
KODA_TUNNEL_ID=demo-tunnel
KODA_TUNNEL_SHARED_TOKEN=replace-with-the-same-long-random-secret

# Gateway runtime
GATEWAY_LOG_LEVEL=INFO
KODA_TUNNEL_RESPONSE_TIMEOUT_SECONDS=30
KODA_TUNNEL_HEARTBEAT_TIMEOUT_SECONDS=45
