# Build and run the local DSL app in packaged mode
SERVE_FRONTEND_DIST=true
FRONTEND_DIST_PATH=frontend/dist

# Public URL users will access through the browser
KODA_PUBLIC_BASE_URL=https://koda.example.com

# Local agent registration
KODA_TUNNEL_SERVER_URL=https://koda.example.com
KODA_TUNNEL_ID=demo-tunnel
KODA_TUNNEL_SHARED_TOKEN=replace-with-the-same-long-random-secret
KODA_TUNNEL_UPSTREAM_URL=http://127.0.0.1:8000

# Local agent tuning
KODA_TUNNEL_HEARTBEAT_INTERVAL_SECONDS=15
KODA_TUNNEL_REQUEST_TIMEOUT_SECONDS=30
KODA_TUNNEL_RECONNECT_DELAY_SECONDS=2
KODA_TUNNEL_MAX_RECONNECT_DELAY_SECONDS=15
KODA_TUNNEL_OPEN_TIMEOUT_SECONDS=10
KODA_TUNNEL_AGENT_LOG_LEVEL=INFO
