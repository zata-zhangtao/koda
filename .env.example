# Local DSL defaults stay development-safe.
# For public packaged mode, copy deploy/public-forward/agent.env.example instead.
SERVE_FRONTEND_DIST=false
FRONTEND_DIST_PATH=frontend/dist

# Public URL users will open in the browser
KODA_PUBLIC_BASE_URL=https://koda.example.com

# Local agent tunnel registration
KODA_TUNNEL_SERVER_URL=https://koda.example.com
KODA_TUNNEL_ID=demo-tunnel
KODA_TUNNEL_SHARED_TOKEN=replace-with-a-long-random-secret
KODA_TUNNEL_UPSTREAM_URL=http://127.0.0.1:8000

# Optional local agent tuning
KODA_TUNNEL_HEARTBEAT_INTERVAL_SECONDS=15
KODA_TUNNEL_REQUEST_TIMEOUT_SECONDS=30
KODA_TUNNEL_RECONNECT_DELAY_SECONDS=2
KODA_TUNNEL_MAX_RECONNECT_DELAY_SECONDS=15
KODA_TUNNEL_OPEN_TIMEOUT_SECONDS=10
KODA_TUNNEL_AGENT_LOG_LEVEL=INFO

# Worktree branch naming
WORKTREE_BRANCH_AI_NAMING_ENABLED=true
WORKTREE_BRANCH_AI_MODEL=qwen-flash
WORKTREE_BRANCH_AI_TIMEOUT_SECONDS=8
